{
  "name": "@nlbs/css",
  "version": "0.2.0",
  "description": "High-performance CSS foundation for Nanoo Labs",
  "main": "dist/nanoo.min.css",
  "unpkg": "dist/nanoo.min.css",
  "jsdelivr": "dist/nanoo.min.css",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nanoolabs/css.git"
  },
  "scripts": {
    "build": "lightningcss --minify --bundle --targets '>= 0.25%' src/main.css -o dist/nanoo.min.css",
    "dev": "lightningcss --bundle src/main.css -o dist/nanoo.css"
  },
  "keywords": [
    "nanoo",
    "css",
    "design-system",
    "minimalist",
    "performance"
  ],
  "author": "Nanoo Labs",
  "license": "ISC",
  "devDependencies": {
    "lightningcss-cli": "^1.32.0"
  }
}
